{
  "display_information": {
    "name": "Multi-Agent Orchestrator",
    "description": "AI agent team that runs tasks in the background and reports back",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "agents",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/agent-status",
        "description": "Show all agents current status (idle/busy)",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "chat:write.public",
        "channels:history",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
