{
  "display_information": {
    "name": "Multi-Agent Orchestrator",
    "description": "AI agent team that runs tasks in the background and reports back",
    "background_color": "#1a1a2e"
  },
  "features": {
    "bot_user": {
      "display_name": "agents",
      "always_online": true
    },
    "slash_commands": [
      {
        "command": "/agent-status",
        "description": "Show all agents current status (idle/busy)",
        "should_escape": false
      },
      {
        "command": "/add-agent",
        "description": "Add a new agent to the team",
        "usage_hint": "<name> <role>",
        "should_escape": false
      },
      {
        "command": "/remove-agent",
        "description": "Remove an agent from the team",
        "usage_hint": "<name>",
        "should_escape": false
      },
      {
        "command": "/add-role",
        "description": "Add a new custom role",
        "usage_hint": "<name> <description>",
        "should_escape": false
      },
      {
        "command": "/list-agents",
        "description": "List all configured agents",
        "should_escape": false
      },
      {
        "command": "/list-roles",
        "description": "List all available roles",
        "should_escape": false
      },
      {
        "command": "/edit-agent",
        "description": "Edit an existing agent's name or role",
        "usage_hint": "<name> [name:<new-name>] [role:<role-name>]",
        "should_escape": false
      },
      {
        "command": "/edit-role",
        "description": "Edit an existing role's name or description",
        "usage_hint": "<name> [name:<new-name>] [description:<new-description>]",
        "should_escape": false
      }
    ]
  },
  "oauth_config": {
    "scopes": {
      "bot": [
        "app_mentions:read",
        "chat:write",
        "chat:write.public",
        "channels:history",
        "commands"
      ]
    }
  },
  "settings": {
    "event_subscriptions": {
      "bot_events": [
        "app_mention"
      ]
    },
    "interactivity": {
      "is_enabled": false
    },
    "org_deploy_enabled": false,
    "socket_mode_enabled": true,
    "token_rotation_enabled": false
  }
}
